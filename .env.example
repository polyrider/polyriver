# PolyRiver environment variables
# Copy to .env.local and fill in your values

# Required: Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Polymarket CLOB endpoint (public, no key needed for read-only)
NEXT_PUBLIC_CLOB_HOST=https://clob.polymarket.com
NEXT_PUBLIC_GAMMA_API=https://gamma-api.polymarket.com

# Large trade threshold in USD (default $500)
LARGE_TRADE_THRESHOLD=500
